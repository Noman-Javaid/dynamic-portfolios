# ===========================================================================
# BACKEND env — copy this file to `supabase/.env`.
#
# These are SERVER-ONLY secrets — never exposed to the browser. They are loaded
# into the Next.js server at startup by `src/instrumentation.ts`, and by the
# seed script directly. Do NOT prefix any of these with NEXT_PUBLIC_.
# ===========================================================================

# Supabase → Project Settings → API → "Project API keys" → service_role / secret
# Bypasses Row Level Security. SERVER ONLY.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Session signing secret. Generate with:  openssl rand -base64 32
SESSION_SECRET=replace-with-a-32+character-random-string

# Seed admin (used once by `npm run seed` to create the first admin user)
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=admin

# Groq — powers the admin "Generate with AI" tab. FREE, OpenAI-compatible.
# Get a key at https://console.groq.com → API Keys → Create API Key.
GROQ_API_KEY=gsk_your-key-here
# Optional — model id, defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional — override the base URL to use another OpenAI-compatible provider.
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Direct Postgres connection string (Project Settings → Database → Connection string)
# Only needed if you run the SQL migration via the Supabase CLI / psql.
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
